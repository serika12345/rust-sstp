#!/usr/bin/env sh
set -eu

cd "$(dirname "$0")/.."

check_absent() {
  rule_name="$1"
  pattern="$2"
  shift 2
  matches="$(mktemp "${TMPDIR:-/tmp}/rust-sstp-architecture.XXXXXX")"
  set +e
  rg -n "$pattern" "$@" > "$matches"
  rule_exit_code="$?"
  set -e
  if [ "$rule_exit_code" -eq 0 ]; then
    echo "構成規則に違反しました: $rule_name" >&2
    cat "$matches" >&2
    rm -f "$matches"
    exit 1
  fi
  rm -f "$matches"
  if [ "$rule_exit_code" -ne 1 ]; then
    echo "構成検査に失敗しました: $rule_name" >&2
    exit "$rule_exit_code"
  fi
}

check_absent "純粋クレートではunsafeを禁止する" \
  'unsafe[[:space:]]+(fn|impl|trait|extern)|unsafe[[:space:]]*\{' \
  crates/sstp-protocol crates/sstp-session -g '*.rs'

check_absent "純粋クレートではI/O依存を禁止する" \
  'std::(env|fs|net|process)|tokio|async_std|smol' \
  crates/sstp-protocol crates/sstp-session -g '*.rs'

check_absent "製品コードでは強制終了相当の近道を禁止する" \
  '\.(unwrap|expect)\(|\b(panic|todo|unimplemented)!' \
  crates -g '*.rs' -g '!**/tests/**'

generic_files="$(find crates -type f \( -name 'utils.rs' -o -name 'common.rs' -o -name 'helpers.rs' -o -name 'types.rs' \) -print)"
if [ -n "$generic_files" ]; then
  echo "汎用的な寄せ集めモジュール名は禁止されています:" >&2
  echo "$generic_files" >&2
  exit 1
fi

oversized="$(find crates -type f -name '*.rs' -print | while IFS= read -r file; do
  line_count="$(wc -l < "$file" | tr -d ' ')"
  if [ "$line_count" -gt 500 ]; then
    echo "$file"
  fi
done)"
if [ -n "$oversized" ]; then
  echo "500行を超えるRustソースファイルは分割または基準登録が必要です:" >&2
  echo "$oversized" >&2
  exit 1
fi

echo "check-architecture: 成功"
