#!/usr/bin/env sh
set -eu

cd "$(dirname "$0")/.."

hook=".git/hooks/pre-commit"
if [ ! -d ".git/hooks" ]; then
  echo "install-pre-commit-hook: .git/hooks が見つかりません" >&2
  exit 1
fi

cat > "$hook" <<'HOOK'
#!/usr/bin/env sh
set -eu

nix develop -c ./scripts/check-no-invisible-chars
nix develop -c ./scripts/check-domain-types
nix develop -c ./scripts/check-architecture
HOOK

chmod +x "$hook"
echo "$hook を導入しました"
