#!/usr/bin/env sh
set -eu

cd "$(dirname "$0")/.."

baseline="scripts/cve-audit-baseline.json"
root_audit_json="$(mktemp "${TMPDIR:-/tmp}/rust-sstp-cargo-audit-root.XXXXXX")"
fuzz_audit_json="$(mktemp "${TMPDIR:-/tmp}/rust-sstp-cargo-audit-fuzz.XXXXXX")"
trap 'rm -f "$root_audit_json" "$fuzz_audit_json"' EXIT

set +e
cargo audit --json > "$root_audit_json"
root_audit_exit_code="$?"
cargo audit --file fuzz/Cargo.lock --json > "$fuzz_audit_json"
fuzz_audit_exit_code="$?"
set -e

python3 - \
  "$baseline" \
  "$root_audit_json" "$root_audit_exit_code" \
  "$fuzz_audit_json" "$fuzz_audit_exit_code" <<'PY'
import json
import sys

baseline_path = sys.argv[1]
audit_arguments = sys.argv[2:]

with open(baseline_path, "r", encoding="utf-8") as handle:
    baseline = json.load(handle)

configured = baseline.get("cargo", {}).get("rustSecIds", [])
if not isinstance(configured, list):
    print(f"{baseline_path} の cargo.rustSecIds は配列で定義してください。", file=sys.stderr)
    sys.exit(2)

allowed = sorted(set(configured))
current_items = set()
for audit_path, audit_status_text in zip(
    audit_arguments[0::2], audit_arguments[1::2], strict=True
):
    audit_status = int(audit_status_text)
    with open(audit_path, "r", encoding="utf-8") as handle:
        audit = json.load(handle)

    vulnerabilities = audit.get("vulnerabilities", {})
    if isinstance(vulnerabilities, dict):
        entries = vulnerabilities.get("list", [])
    elif isinstance(vulnerabilities, list):
        entries = vulnerabilities
    else:
        entries = []

    current_items.update(
        entry.get("advisory", {}).get("id")
        for entry in entries
        if isinstance(entry, dict) and entry.get("advisory", {}).get("id")
    )
    if audit_status not in (0, 1):
        print(
            f"cargo auditが{audit_path}の検査で終了状態 {audit_status} により失敗しました。",
            file=sys.stderr,
        )
        sys.exit(audit_status)

current = sorted(current_items)
unexpected = [item for item in current if item not in allowed]
stale = [item for item in allowed if item not in current]

if unexpected:
    print("基準にないRustSec勧告が見つかりました:", file=sys.stderr)
    for item in unexpected:
        print(f"  {item}", file=sys.stderr)
    sys.exit(1)

if stale:
    print("不要になったRustSec基準項目が見つかりました:", file=sys.stderr)
    for item in stale:
        print(f"  {item}", file=sys.stderr)
    sys.exit(1)

print(f"verify-cves: 成功（基準で追跡するRustSec勧告は{len(current)}件）")
PY
